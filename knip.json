{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "project": ["src/**/*.{ts,svelte}"],
      "ignore": ["src/vite-env.d.ts", "packages/*/dist/**", "packages/*/src/**", "packages/*/build.ts"],
      "paths": {
        "$lib/*": ["src/lib/*"],
        "$components/*": ["src/components/*"],
        "$pages/*": ["src/pages/*"],
        "@devbox/*/template": ["packages/*/dist/template.ts"]
      },
      "ignoreDependencies": ["tailwindcss"]
    },
    "packages/*": {
      "ignore": ["**"]
    }
  },
  "ignoreExportsUsedInFile": true,
  "rules": {
    "unlisted": "error",
    "binaries": "error",
    "unresolved": "error",
    "exports": "warn",
    "types": "warn"
  }
}
